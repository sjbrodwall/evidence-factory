{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Train",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/src/train.py",
      "args": ["--out-dir", "build", "--seed", "42"],
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Eval",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/src/eval.py",
      "args": ["--build-dir", "build", "--out", "build/eval.json"],
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Assemble evidence pack",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/make_evidence_pack.py",
      "args": [
        "--build-dir", "build",
        "--evidence-dir", "evidence",
        "--out-tgz", "evidence/evidence-pack.tgz"
      ],
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Policy gate (Conftest)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/run_policy_gate.py",
      "cwd": "${workspaceFolder}"
    }
  ],
  "compounds": [
    {
      "name": "Evidence factory (full)",
      "configurations": ["Train", "Eval", "Assemble evidence pack", "Policy gate (Conftest)"]
    }
  ]
}
